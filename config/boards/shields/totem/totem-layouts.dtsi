#include <physical_layouts.dtsi>

/ {
    totem_layout: totem_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys = <
            /* Top Row */
            &key_physical_attrs 100 100 100 100 0 0 0
            &key_physical_attrs 100 100 200 50 0 0 0
            &key_physical_attrs 100 100 300 0 0 0 0
            &key_physical_attrs 100 100 400 50 0 0 0
            &key_physical_attrs 100 100 500 100 0 0 0
            
            &key_physical_attrs 100 100 800 100 0 0 0
            &key_physical_attrs 100 100 900 50 0 0 0
            &key_physical_attrs 100 100 1000 0 0 0 0
            &key_physical_attrs 100 100 1100 50 0 0 0
            &key_physical_attrs 100 100 1200 100 0 0 0

            /* Home Row */
            &key_physical_attrs 100 100 100 200 0 0 0
            &key_physical_attrs 100 100 200 150 0 0 0
            &key_physical_attrs 100 100 300 100 0 0 0
            &key_physical_attrs 100 100 400 150 0 0 0
            &key_physical_attrs 100 100 500 200 0 0 0

            &key_physical_attrs 100 100 800 200 0 0 0
            &key_physical_attrs 100 100 900 150 0 0 0
            &key_physical_attrs 100 100 1000 100 0 0 0
            &key_physical_attrs 100 100 1100 150 0 0 0
            &key_physical_attrs 100 100 1200 200 0 0 0

            /* Bottom Row + Outer Pinkies */
            &key_physical_attrs 100 100 0 350 0 0 0     /* RC(3,0) */
            &key_physical_attrs 100 100 100 300 0 0 0   /* RC(2,0) */
            &key_physical_attrs 100 100 200 250 0 0 0   /* RC(2,1) */
            &key_physical_attrs 100 100 300 200 0 0 0   /* RC(2,2) */
            &key_physical_attrs 100 100 400 250 0 0 0   /* RC(2,3) */
            &key_physical_attrs 100 100 500 300 0 0 0   /* RC(2,4) */

            &key_physical_attrs 100 100 800 300 0 0 0   /* RC(2,5) */
            &key_physical_attrs 100 100 900 250 0 0 0   /* RC(2,6) */
            &key_physical_attrs 100 100 1000 200 0 0 0  /* RC(2,7) */
            &key_physical_attrs 100 100 1100 250 0 0 0  /* RC(2,8) */
            &key_physical_attrs 100 100 1200 300 0 0 0  /* RC(2,9) */
            &key_physical_attrs 100 100 1300 350 0 0 0  /* RC(3,9) */

            /* Thumb Cluster */
            &key_physical_attrs 100 100 350 400 (-1500) 0 0 /* RC(3,2) */
            &key_physical_attrs 100 100 450 450 0 0 0       /* RC(3,3) */
            &key_physical_attrs 100 100 550 500 1500 0 0    /* RC(3,4) */

            &key_physical_attrs 100 100 750 500 (-1500) 0 0 /* RC(3,5) */
            &key_physical_attrs 100 100 850 450 0 0 0       /* RC(3,6) */
            &key_physical_attrs 100 100 950 400 1500 0 0    /* RC(3,7) */
        >;
    };
};
